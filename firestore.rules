rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Configuration doc: create this manually in the console with field `pinHash` set to
    // the master PIN hash from your app (e.g. H_MASTER in index(6).html).
    // Make this doc read-only from client-side (writes disabled by rules).
    match /cashbook/config {
      allow read: if true;
      allow write: if false;
    }

    // Main cashbook doc: allow reads for clients, but restrict writes to either
    // authenticated users OR clients that supply the correct PIN hash in the
    // write payload (field `_pinHash`) which must match the stored config.pinHash.
    match /cashbook/main {
      allow read: if true;

      allow create, update, delete: if (
        // standard authenticated users (optional)
        request.auth != null
        ||
        // OR client supplies a _pinHash that matches the config doc
        (request.resource.data._pinHash != null
          && request.resource.data._pinHash == get(/databases/$(database)/documents/cashbook/config).data.pinHash)
      );
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
